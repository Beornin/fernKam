# fernKam backend environment variables
# Copy to .env and fill in real values

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
PG_URL=postgresql+asyncpg://fernkam_user:changeme@localhost:5432/fernkam
PG_URL_SYNC=postgresql+psycopg2://fernkam_user:changeme@localhost:5432/fernkam

# ── DigiKam MariaDB (import only) ─────────────────────────────────────────────
MYSQL_URL=mysql+pymysql://root@localhost:3306/digikam

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=fernKam
DEBUG=false
LIBRARY_ROOT=D:/Pictures and Videos

# ── Thumbnails ────────────────────────────────────────────────────────────────
THUMB_CACHE_DIR=data/thumbnails

# ── Optional extensions (set to true after installing pgvector/postgis) ───────
HAS_PGVECTOR=false
HAS_POSTGIS=false
